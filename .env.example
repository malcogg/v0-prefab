## Neon (Postgres)
# Get this from your Neon project dashboard (Connection string).
NEON_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

## Resend (transactional email)
# https://resend.com/api-keys — never commit the real key.
RESEND_API_KEY="re_xxxxxxxx"
# Optional: verified domain sender, e.g. "PreFabricated.co <hello@yourdomain.com>"
# Defaults to Resend onboarding sender for testing.
# RESEND_FROM_EMAIL="PreFabricated.co <onboarding@resend.dev>"
# Optional: override team inbox for lead notifications (defaults to prefabflorida@gmail.com in code).
# RESEND_TEAM_EMAIL="prefabflorida@gmail.com"

